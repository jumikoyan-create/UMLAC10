<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.poli.contexto3.controlador.PrimaryController"
            prefWidth="1000" prefHeight="680">

    <!-- ══════════════════════════════════════════
         MENÚ IZQUIERDO
    ══════════════════════════════════════════ -->
    <left>
        <VBox spacing="6" prefWidth="210"
              style="-fx-padding: 12; -fx-background-color: #1a1a2e;">

            <Label text="🌌 Sistema Espacial"
                   style="-fx-text-fill: #e0e0ff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Separator/>

            <!-- MODO REGISTRO -->
            <Label text="REGISTRAR" style="-fx-text-fill: #888; -fx-font-size: 10px;"/>

            <Button text="👨‍🚀  Astronauta"    onAction="#activarModoAstronauta"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🔬  Científico"    onAction="#activarModoCientifico"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🌍  Suelo"          onAction="#activarModoSuelo"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🪐  Planeta"        onAction="#activarModoPlaneta"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🚀  Misión"         onAction="#activarModoMision"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🛸  Nave"           onAction="#activarModoNave"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="📦  Contenedor"     onAction="#activarModoContenedor"
                    maxWidth="Infinity"
                    style="-fx-background-color: #16213e; -fx-text-fill: #a0c4ff;"/>
            <Button text="🪨  Muestra"        onAction="#activarModoMuestra"
                    maxWidth="Infinity"
                    style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Separator/>

            <!-- CRUD -->
            <Label text="OPERACIONES" style="-fx-text-fill: #888; -fx-font-size: 10px;"/>

            <Button text="✔  Crear / Guardar"      onAction="#crear"
                    maxWidth="Infinity"
                    style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
            <Button text="🔍  Buscar por ID"        onAction="#buscar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1565c0; -fx-text-fill: white;"/>
            <Button text="✏  Actualizar seleccionado" onAction="#actualizar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e65100; -fx-text-fill: white;"/>
            <Button text="🗑  Eliminar seleccionado"  onAction="#eliminar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #b71c1c; -fx-text-fill: white;"/>
            <Button text="📋  Listar todos"           onAction="#listar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #37474f; -fx-text-fill: white;"/>

            <Separator/>

            <!-- PERSISTENCIA -->
            <Label text="PERSISTENCIA" style="-fx-text-fill: #888; -fx-font-size: 10px;"/>

            <Button text="💾  Serializar"   onAction="#serializar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4a148c; -fx-text-fill: white;"/>
            <Button text="📂  Deserializar" onAction="#deserializar"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4a148c; -fx-text-fill: white;"/>

            <Separator/>
            <Button text="🧹  Limpiar campos" onAction="#limpiarCampos"
                    maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════════
         CONTENIDO CENTRAL
    ══════════════════════════════════════════ -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <!-- FORMULARIO -->
            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="160" prefWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS" prefWidth="320"/>
                </columnConstraints>

                <!-- ID -->
                <Label text="ID:" style="-fx-font-weight: bold;"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtId" promptText="Ej: A001"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <!-- Nombre -->
                <Label text="Nombre:" style="-fx-font-weight: bold;"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNombre" promptText="Nombre descriptivo"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Extra 1 (dinámico) -->
                <Label fx:id="lblExtra1" text="Campo 1:" style="-fx-font-weight: bold;"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtExtra1" promptText="Valor"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <!-- Extra 2 (dinámico) -->
                <Label fx:id="lblExtra2" text="Campo 2:" style="-fx-font-weight: bold;"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtExtra2" promptText="Valor"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <!-- Extra 3 (dinámico, oculto por defecto) -->
                <Label fx:id="lblExtra3" text="Campo 3:" style="-fx-font-weight: bold;"
                       managed="false" visible="false"
                       GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtExtra3" promptText="Valor"
                           managed="false" visible="false"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <!-- ComboBox Astronauta -->
                <Label fx:id="lblCmbAstronauta" text="Astronauta recolector:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbAstronauta" promptText="Selecciona astronauta"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <!-- ComboBox Científico -->
                <Label fx:id="lblCmbCientifico" text="Científico analizador:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbCientifico" promptText="Selecciona científico"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <!-- ComboBox Suelo -->
                <Label fx:id="lblCmbSuelo" text="Suelo:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbSuelo" promptText="Selecciona suelo"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <!-- ComboBox Planeta -->
                <Label fx:id="lblCmbPlaneta" text="Planeta de origen:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbPlaneta" promptText="Selecciona planeta"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                <!-- ComboBox Misión -->
                <Label fx:id="lblCmbMision" text="Misión:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbMision" promptText="Selecciona misión"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                <!-- ComboBox Contenedor -->
                <Label fx:id="lblCmbContenedor" text="Contenedor:"
                       style="-fx-font-weight: bold;" managed="false" visible="false"
                       GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cmbContenedor" promptText="Selecciona contenedor"
                          maxWidth="Infinity" managed="false" visible="false"
                          GridPane.rowIndex="10" GridPane.columnIndex="1"/>
            </GridPane>

            <!-- ESTADO -->
            <Label fx:id="lblEstado" text="" wrapText="true"
                   style="-fx-font-size: 12px; -fx-text-fill: gray;"/>

            <!-- TABLA -->
            <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"      prefWidth="80"/>
                    <TableColumn fx:id="colNombre"   text="Nombre"  prefWidth="160"/>
                    <TableColumn fx:id="colTipo"     text="Tipo"    prefWidth="110"/>
                    <TableColumn fx:id="colDetalle"  text="Detalle" prefWidth="420"/>
                </columns>
                <placeholder>
                    <Label text="Sin registros. Usa el menú izquierdo para agregar datos."/>
                </placeholder>
            </TableView>

        </VBox>
    </center>

</BorderPane>