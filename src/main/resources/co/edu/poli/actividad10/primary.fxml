<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="640.0" prefWidth="700.0"
    xmlns="http://javafx.com/javafx/11"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="co.edu.poli.contexto3.controlador.PrimaryController"
    style="-fx-background-color: #f0f4f8;">

    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Sistema CRUD - Personas"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;">
                <font><Font name="High Tower Text" size="26.0"/></font>
            </Label>
            <Label text="Científicos y Astronautas"
                   style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="12.0" style="-fx-padding: 15;">

            <HBox spacing="20.0" alignment="CENTER_LEFT">
                <VBox spacing="5.0">
                    <Label text="Operación:" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="cmbOperacion" prefWidth="180.0"
                              promptText="Seleccione operación"
                              onAction="#mostrarFormulario"
                              style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Tipo de Persona:" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <ComboBox fx:id="cmbTipo" prefWidth="180.0"
                              promptText="Científico / Astronauta"
                              onAction="#mostrarFormulario"
                              style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                </VBox>
            </HBox>

            <VBox fx:id="panelFormulario" spacing="10.0" managed="false" visible="false"
                  style="-fx-background-color: white; -fx-background-radius: 10;
                         -fx-border-color: #dcdde1; -fx-border-radius: 10; -fx-padding: 15;">

                <Label fx:id="lblTituloFormulario" text="Datos"
                       style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>

                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120.0"/>
                        <ColumnConstraints hgrow="ALWAYS" prefWidth="250.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints prefHeight="32.0"/>
                        <RowConstraints prefHeight="32.0"/>
                        <RowConstraints prefHeight="32.0"/>
                        <RowConstraints prefHeight="32.0"/>
                    </rowConstraints>

                    <Label text="ID:" style="-fx-font-size: 13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtId" promptText="Ingrese ID"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dcdde1; -fx-padding: 5;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Nombre:" style="-fx-font-size: 13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtNombre" promptText="Ingrese nombre"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dcdde1; -fx-padding: 5;"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                  
                    <Label text="Sexo:" style="-fx-font-size: 13px;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="cmbSexo" prefWidth="200.0"
                              style="-fx-background-radius: 8; -fx-border-radius: 8;"
                              GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <!-- Experiencia (solo Científico) -->
                    <Label fx:id="lblExperiencia" text="Experiencia:" style="-fx-font-size: 13px;"
                           managed="false" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtExperiencia" promptText="Ingrese experiencia"
                               managed="false" visible="false"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dcdde1; -fx-padding: 5;"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label fx:id="lblEspecialidad" text="Especialidad:" style="-fx-font-size: 13px;"
                           managed="false" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtEspecialidad" promptText="Ingrese especialidad"
                               managed="false" visible="false"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dcdde1; -fx-padding: 5;"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>

                <!-- Botones del formulario -->
                <HBox spacing="10.0">
                    <Button fx:id="btnEjecutar" text="▶ Ejecutar"
                            onAction="#ejecutarOperacion"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 20 7 20;"/>
                    <Button text="🧹 Limpiar" onAction="#limpiar"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 20 7 20;"/>
                </HBox>
            </VBox>

            <!-- ═══ TABLA ═══ -->
            <TableView fx:id="tablaPersona" prefHeight="180.0" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                <columns>
                    <TableColumn fx:id="colTipo"        text="Tipo"         prefWidth="110.0"/>
                    <TableColumn fx:id="colId"           text="ID"           prefWidth="80.0"/>
                    <TableColumn fx:id="colNombre"       text="Nombre"       prefWidth="150.0"/>
                    <TableColumn fx:id="colSexo"         text="Sexo"         prefWidth="60.0"/>
                    <!-- Columna extra: muestra Experiencia o Especialidad según tipo -->
                    <TableColumn fx:id="colExtra"        text="Exp/Especialidad" prefWidth="160.0"/>
                </columns>
            </TableView>

           
            <TextArea fx:id="txtResultado" prefHeight="80.0" editable="false"
                      style="-fx-background-radius: 8; -fx-border-color: #dcdde1;
                             -fx-border-radius: 8; -fx-font-size: 12px;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="10.0"
              style="-fx-background-color: #ecf0f1; -fx-padding: 12;">
            <Button text="💾 Guardar" onAction="#guardar"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 15 7 15;"/>
            <Button text="📂 Cargar"  onAction="#cargar"
                    style="-fx-background-color: #16a085; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 15 7 15;"/>
            <Button text="📋 Listar"  onAction="#listar"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 15 7 15;"/>
            <Button text="🚪 Salir"   onAction="#salir"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 7 15 7 15;"/>
        </HBox>
    </bottom>

</BorderPane>